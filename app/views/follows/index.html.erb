<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<% end %>

<div class="container mx-auto px-4 pb-5" style="max-width: 1140px;">
  <div class="text-center mb-4">
    <h1 class="page-title mt-4 mb-2">My Circle</h1>
    <p class="text-muted mb-0" style="font-size: .9375rem; font-weight: 500; letter-spacing: .02em;">The people you care about, all in one place.</p>
  </div>

  <div class="app-card mx-auto mb-5" style="max-width: 640px;">
    <p class="section-header mb-2" style="font-size: .6875rem;">Add someone to your circle</p>
    <%= form_with url: follows_path, method: :post, local: true, class: "d-flex", html: { style: "gap: .75rem;" } do %>
      <input type="email" name="email" class="form-control flex-grow-1" style="border-radius: 12px; border-color: #E2E8F0; padding: .625rem .875rem;" placeholder="Enter their MediLink email" required>
      <button type="submit" class="btn btn-primary btn-action text-nowrap" style="border-radius: 12px; padding: .625rem 1.5rem;">Follow</button>
    <% end %>
  </div>

  <section class="mb-4">
    <h2 class="mb-3">People you follow</h2>
    <% if @following.empty? %>
      <p class="text-muted text-center">You're not following anyone yet.</p>
    <% else %>
      <div class="row g-4 justify-content-center">
        <% @following.each do |followed_user| %>
          <%= render "followed_user_card", followed_user: followed_user %>
        <% end %>
      </div>
    <% end %>
  </section>

  <hr class="medications-divider">

  <section>
    <h2 class="mb-3">People following you</h2>
    <% if @followers.empty? %>
      <p class="text-muted text-center">No one is following you yet.</p>
    <% else %>
      <div class="row g-4 justify-content-center">
        <% @followers.each do |follower| %>
          <%= render "follower_card", follower: follower %>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
