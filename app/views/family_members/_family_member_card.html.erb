<div class="col-12 col-md-6 col-lg-4">
  <div class="medication-card position-relative p-4 h-100 bg-white">
    <div class="medication-card__actions position-absolute d-flex gap-2">
      <%= link_to edit_family_member_path(family_member) do %>
        <i class="bi bi-pencil"></i>
      <% end %>
      <%= button_to family_member_path(family_member), method: :delete, class: "btn btn-link p-0 border-0", form: { data: { turbo_confirm: "Are you sure you want to delete this family member?" } } do %>
        <i class="bi bi-trash"></i>
      <% end %>
    </div>

    <h3 class="medication-card__name mb-1"><%= family_member.first_name %> <%= family_member.last_name %></h3>
    <p class="medication-card__meta text-muted mb-2"><%= family_member.status %></p>
    <% if family_member.caregiver %>
      <p class="medication-card__meta text-muted mb-3">
        <i class="bi bi-person-check"></i> Caregiver: <%= family_member.caregiver.email %>
      </p>
    <% end %>

    <%= link_to "View medications", medications_path(family_member_id: family_member.id), class: "btn btn-outline-primary btn-sm" %>
  </div>
</div>
