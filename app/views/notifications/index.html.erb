<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<% end %>

<div class="container mt-4">
  <h1 class="mb-4">Notifications</h1>

  <% if @notifications.empty? %>
    <p class="text-muted">No notifications yet.</p>
  <% else %>
    <% @notifications.each do |notification| %>
      <div class="card mb-3 <%= "bg-primary-subtle" unless notification.read? %>">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <p class="mb-1"><%= notification.message %></p>
            <small class="text-muted"><%= time_ago_in_words(notification.created_at) %> ago</small>
          </div>
          <%= button_to notification_path(notification), method: :delete, class: "btn btn-link p-0 border-0", form: { data: { turbo_confirm: "Delete this notification?" } } do %>
            <i class="bi bi-trash"></i>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
