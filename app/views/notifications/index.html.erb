<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<% end %>

<div class="container mx-auto px-4 pb-5" style="max-width: 720px;">
  <div class="text-center mb-5 position-relative">
    <h1 class="page-title mt-4 mb-2">Notifications 🔔</h1>
    <% if @has_unread %>
      <%= link_to "Mark all as read", notifications_path, class: "btn btn-outline-primary btn-sm position-absolute top-0 end-0" %>
    <% end %>
  </div>

  <% if @notifications.empty? %>
    <div class="text-center py-5">
      <p class="mb-2" style="font-size: 2rem;">🔔</p>
      <p class="mb-1" style="font-size: 1.125rem; font-weight: 600; color: #0F172A;">No notifications yet</p>
      <p class="text-muted mb-0" style="font-size: .9375rem;">You'll see updates here when your circle takes their medications.</p>
    </div>
  <% else %>
    <% @notifications_by_day.each do |date, day_notifications| %>
      <% label = if date == Date.current
                   "Today"
                 elsif date == Date.current - 1.day
                   "Yesterday"
                 else
                   date.strftime("%B %-d")
                 end %>
      <h2 class="mb-3" style="font-weight: 600; color: #0F172A; text-transform: uppercase;"><%= label %></h2>

      <% day_notifications.each do |notification| %>
        <div class="d-flex align-items-center gap-3 mb-3" style="background-color: #FFFFFF; border: 1px solid #E2E8F0; border-radius: 1rem; padding: 1rem 1.25rem; box-shadow: 0 1px 6px rgba(15, 23, 42, 0.04);">
          <%= render "shared/user_avatar", user: notification.medication.user, size: 48 %>

          <div class="flex-grow-1">
            <p class="mb-0" style="font-size: .9375rem; font-weight: 600; color: #0F172A;"><%= notification.message %></p>
            <p class="text-muted mb-0" style="font-size: .8125rem; font-weight: 500;">
              <%= notification.status == :taken ? "Taken at" : "Missed at" %> <%= notification.medication.reminder_time %>
            </p>
          </div>

          <% if notification.status == :taken %>
            <span class="badge badge-success-soft rounded-pill" style="font-size: .75rem; font-weight: 600; padding: .375rem .875rem;">✓ Viewed</span>
          <% else %>
            <span class="badge badge-danger-soft rounded-pill" style="font-size: .75rem; font-weight: 600; padding: .375rem .875rem;">Missed</span>
          <% end %>

          <%= button_to notification_path(notification), method: :delete, class: "btn btn-link p-0 border-0", form: { data: { turbo_confirm: "Delete this notification?" } } do %>
            <i class="bi bi-trash icon-muted" style="font-size: .875rem;"></i>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
