<%= turbo_stream_from @chat %>

<div class="container">

  <div class="row">
    <div class="col-4">
      <h2>Past Conversations</h2>
      <h4><%= @medication.name %></h4>

      <div class="mb-4">
        <% if @chats.any? %>
          <ul class="list-unstyled">
            <% @chats.each do |chat| %>
              <li class="mb-2">
                <%= link_to chat.title, chat_path(chat), class: "text-decoration-none" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p> There are no chats yet.</p>
        <% end %>
      </div>
    </div>

    <div class="col-8">

      <h1 id="chat_title"><%= @chat.title %></h1>

      <div id="messages">
       <%= render "messages/messages", messages:@chat.messages %>
      </div>

      <div id="new_message_container" class="mt-4">
        <%= render "messages/form", chat: @chat, message: @message %>
      </div>

    </div>
  </div>

  <%= button_to "New Chat", medication_chats_path(@medication)%>

</div>
