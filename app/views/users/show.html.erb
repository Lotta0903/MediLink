<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<% end %>

<div class="container mt-4 d-flex justify-content-center">
  <div class="card shadow-sm rounded-4 p-4 text-center" style="max-width: 500px; width: 100%;">
    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3"
         style="width: 150px; height: 150px; font-size: 3rem;">
      <%= @user.initials %>
    </div>

    <h2 class="fw-bold mb-1"><%= @user.full_name %></h2>
    <p class="text-muted small mb-4"><%= @user.email %></p>

    <%= link_to "Edit profile", edit_user_registration_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="text-center mt-3">
  <%= link_to "View family members", follows_path, class: "btn btn-outline-secondary" %>
</div>
