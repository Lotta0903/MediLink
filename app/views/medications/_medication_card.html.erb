<div class="col-12 col-md-4 h-100">
  <div class="medication-card-wrapper mx-auto d-flex flex-column position-relative" style="max-width: 320px; min-height: 240px; height: 100%; background-color: #FFFFFF; border: 1.5px solid #CFFAFE; border-radius: 1.25rem; padding: 1rem; box-shadow: 0 4px 20px rgba(14, 165, 233, 0.08);">
    <div class="position-absolute d-flex" style="top: .75rem; right: .75rem; gap: .5rem;">
      <%= link_to edit_medication_path(medication) do %>
        <i class="bi bi-pencil icon-muted" style="font-size: .875rem;"></i>
      <% end %>
      <%= button_to medication_path(medication), method: :delete, class: "btn btn-link p-0 border-0", form: { data: { turbo_confirm: "Are you sure you want to delete this medication?" } } do %>
        <i class="bi bi-trash icon-muted" style="font-size: .875rem;"></i>
      <% end %>
    </div>

    <div class="d-flex flex-column align-items-center text-center flex-grow-1 justify-content-center" style="gap: .5rem;">
      <p class="text-primary mb-0" style="font-size: 1.625rem; font-weight: 700;"><%= medication.reminder_time %></p>

      <div class="d-flex align-items-center justify-content-center" style="gap: .625rem;">
        <span style="font-size: 18px; line-height: 1;">💊</span>
        <p class="mb-0" style="font-size: 1.5rem; font-weight: 800; color: #0F172A; text-transform: uppercase; letter-spacing: .03em;"><%= medication.name %></p>
      </div>

      <p class="mb-0" style="font-size: 1.25rem; font-weight: 700; color: #0F172A; text-transform: uppercase;"><%= medication.dosage %></p>
      <p class="text-muted mb-0" style="font-size: .75rem; font-weight: 500;"><%= medication.frequency %></p>
    </div>

    <div class="mt-auto text-center pt-2">
      <div class="d-flex flex-nowrap justify-content-center align-items-center" style="gap: .5rem;">
        <% if medication.taken_today? %>
          <span class="badge rounded-pill d-inline-flex align-items-center justify-content-center" style="background-color: #10B981; color: #FFFFFF; font-size: .6875rem; font-weight: 600; padding: .5rem 1rem; letter-spacing: .03em; white-space: nowrap; text-align: center;">
            ✓ TAKEN <%= medication.last_taken_time %>
          </span>
        <% else %>
          <%= button_to "✓ Mark as taken", medication_medication_logs_path(medication),
                method: :post,
                class: "btn btn-mark-taken btn-action rounded-pill text-uppercase d-inline-flex align-items-center justify-content-center",
                style: "padding: .5rem 1rem; font-size: .6875rem; font-weight: 600; letter-spacing: .03em; white-space: nowrap; text-align: center;",
                data: { controller: "taken-button", action: "click->taken-button#flash" } %>
        <% end %>

        <%= link_to medication_path(medication), class: "btn btn-medibot-pill rounded-pill text-uppercase text-decoration-none d-inline-flex align-items-center justify-content-center", style: "padding: .5rem 1rem; font-size: .6875rem; font-weight: 600; letter-spacing: .03em; white-space: nowrap; text-align: center;" do %>
          💬 Ask MediBot
        <% end %>
      </div>
    </div>
  </div>
</div>
