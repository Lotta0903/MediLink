<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<% end %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
      <% if @family_member %>
        Medications for <%= @family_member.first_name %> <%= @family_member.last_name %>
      <% else %>
        My medications
      <% end %>
    </h1>
    <%= link_to "Add a medication", new_medication_path(family_member_id: @family_member&.id), class: "btn btn-primary" %>
  </div>

  <% if @medications.empty? %>
    <p class="text-muted">No medications yet.</p>
  <% else %>
    <% upcoming = @medications.reject(&:taken_today?) %>
    <% taken_today = @medications.select(&:taken_today?) %>

    <section class="mb-4">
      <h2 class="section-header">Upcoming</h2>
      <% if upcoming.empty? %>
        <p class="text-muted">Nothing left to take today.</p>
      <% else %>
        <div class="row g-3">
          <% upcoming.each do |medication| %>
            <%= render "medication_card", medication: medication %>
            <%= button_to "medibot", medication_chats_path(medication)%>
          <% end %>
        </div>
      <% end %>
    </section>

    <hr class="medications-divider">

    <section>
      <h2 class="section-header">Taken today</h2>
      <% if taken_today.empty? %>
        <p class="text-muted">No medications taken yet today.</p>
      <% else %>
        <div class="row g-3">
          <% taken_today.each do |medication| %>
            <%= render "medication_card", medication: medication %>
          <% end %>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
